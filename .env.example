PORT=4000
NODE_ENV=development

# Local Docker/Postgres URL (default dev setup)
DATABASE_URL=postgres://postgres:postgres@localhost:5433/news_api_dev

# Optional for remote databases (e.g. Railway from local machine):
# DATABASE_PUBLIC_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#
# Optional SSL override:
# true  => always enable SSL
# false => always disable SSL
# If omitted, SSL auto-enables for non-local hosts.
# DATABASE_SSL=true

# Safety override for destructive DB scripts on non-local databases:
# ALLOW_DESTRUCTIVE_DB_OPERATIONS=true
